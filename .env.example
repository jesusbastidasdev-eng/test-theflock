# Copy to `.env` at repo root for tooling that reads it, or export in your shell.
# API (apps/api) — required
DATABASE_URL=postgresql://chirp:chirp@127.0.0.1:5432/chirp?schema=public

# API server
API_PORT=4000
# Origin of the Next.js app (CORS + cookie context). Must match how you open the UI in the browser.
WEB_ORIGIN=http://127.0.0.1:3000

# Next.js (apps/web) — optional; defaults shown
# Where Next.js dev server proxies /api/* (Fastify).
API_ORIGIN=http://127.0.0.1:4000
# Server-side fetches from Node (rare in this app; browser uses same-origin /api).
API_INTERNAL_URL=http://127.0.0.1:4000
